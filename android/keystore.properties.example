# Copy this file to android/keystore.properties and fill in YOUR real values.
# android/keystore.properties is gitignored — it (and the .jks file) must never
# be committed. This is the upload key for Google Play; if you lose it you can
# reset it via Play App Signing, but keep a secure backup anyway.
#
# storeFile is resolved relative to the android/app/ directory (where build.gradle
# lives), so "upload-keystore.jks" means android/app/upload-keystore.jks.

storeFile=upload-keystore.jks
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
