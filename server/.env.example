PORT=3000
JWT_SECRET=replace-with-a-long-random-string
# Admin dashboard key. When set, GET /api/admin/stats (and the /admin.html page)
# return usage stats to anyone who supplies this key (?key= or x-admin-key header).
# Leave UNSET to disable the admin endpoint entirely.
ADMIN_KEY=
# Comma-separated list of allowed origins for the API + WebSocket. Setting this
# to `*` allows ANY origin and is INSECURE for production — use your real
# domain(s) instead. The production web origins are always allowed automatically.
CORS_ORIGIN=https://your-domain.com
# Ranked play seasonal switch. Ranked matchmaking (1v1, 2v2, checkers) is OFF by
# DEFAULT ("coming soon"). Set to 1 or true (case-insensitive) to enable ranked
# play. When off, GET /api/config returns { rankedEnabled:false } AND the server
# rejects ranked matchmaking socket joins (mm_join/team_mm_join/checkers_mm_join);
# casual/friendly/rematch paths are unaffected.
RANKED_ENABLED=
DATABASE_PATH=./data.db
# --- Scalable persistence tier (horizontal scaling) -------------------------
# By DEFAULT the server uses a single embedded SQLite file (DATABASE_PATH above)
# — zero config, perfect for local dev and the test suite.
# For HORIZONTAL SCALING across replicas (alongside REDIS_URL for the socket
# layer), set BOTH of these to switch to a node-postgres connection pool:
#   DB_BACKEND=postgres
#   DATABASE_URL=postgres://user:pass@host:5432/chesstrophies
# IMPORTANT: Postgres is opt-in via DB_BACKEND=postgres ON PURPOSE. Presence of
# DATABASE_URL alone does NOT switch backends — hosting platforms (Railway, etc.)
# auto-inject DATABASE_URL when a Postgres add-on exists, which would otherwise
# silently flip the app onto Postgres and crash boot if that DB lacks our schema.
# DB_BACKEND=
# DATABASE_URL=
# Postgres pool tuning + TLS (only used when DB_BACKEND=postgres):
#   PGPOOL_MAX  - max pooled connections per replica (default 10)
#   PGSSL       - 1 to force TLS (rejectUnauthorized:false), 0 to disable.
#                 Default: TLS on for non-localhost URLs (managed DBs need it).
SERVE_CLIENT=false
# Transactional email via Resend (https://resend.com), used for password-reset
# AND email-verification links. If RESEND_API_KEY is unset, email sending is a
# no-op and the devToken fallbacks below are used instead. APP_URL builds the
# links in the emails (reset: /reset?token=..., verify: /?verify=...).
RESEND_API_KEY=
RESEND_FROM=ChessTrophies <onboarding@resend.dev>
APP_URL=https://your-deployment.example.com
# Dev-only escape hatch: when set to 1, POST /api/auth/forgot returns the raw
# reset token in the response (`devToken`) so the reset flow can be tested
# without email. MUST stay unset (or != 1) in production -- otherwise anyone can
# obtain a usable password-reset token for any account.
EXPOSE_RESET_TOKEN=
# Same idea for email verification: when set to 1, POST /api/auth/signup and
# /api/auth/resend-verification return the 6-digit code (`devVerifyCode`) so the
# verify flow can be tested without email. MUST stay unset (or != 1) in prod.
EXPOSE_VERIFY_TOKEN=
