PORT=3000
JWT_SECRET=replace-with-a-long-random-string
CORS_ORIGIN=*
DATABASE_PATH=./data.db
SERVE_CLIENT=false
# Password-reset email via Resend (https://resend.com). If RESEND_API_KEY is
# unset, email sending is a no-op and the /api/auth/forgot devToken fallback is
# used instead. APP_URL is used to build the reset link in the email.
RESEND_API_KEY=
RESEND_FROM=ChessTrophies <onboarding@resend.dev>
APP_URL=https://your-deployment.example.com
