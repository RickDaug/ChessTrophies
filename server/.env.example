# ChessTrophies server environment template.
# Copy this to `.env` (which is gitignored) and fill in real values.
# Generate JWT_SECRET via:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"

# REQUIRED in production. Server will refuse to start if NODE_ENV=production
# and this is unset.
JWT_SECRET=replace-with-a-long-random-string

PORT=3000

# SQLite file path. On Railway, mount a persistent volume and point this at it.
DATABASE_PATH=./data.db

# Comma-separated allowlist of client origins. Use '*' in dev only.
# Production example: https://chesstrophies.com,https://www.chesstrophies.com
CORS_ORIGIN=*

# Set to 'false' if the client is hosted separately (e.g. Vercel) and the
# server should not also serve ../public.
SERVE_CLIENT=true

# Node environment. Set to 'production' on deploy.
NODE_ENV=development
